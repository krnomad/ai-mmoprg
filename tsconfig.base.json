{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "dist",
    "baseUrl": ".",
    "paths": {
      "@ai-mmoprg/shared": ["packages/shared/src/index.ts"],
      "@ai-mmoprg/protocol": ["packages/protocol/src/index.ts"],
      "@ai-mmoprg/agent-runtime": ["packages/agent-runtime/src/index.ts"]
    }
  }
}
